{
  "channel_payloads": {
    "none": null,
    "slack_webhook": "runs/notification_slack.json",
    "feishu_webhook": "runs/notification_feishu.json"
  },
  "rules": [
    {
      "event_names": ["schedule"],
      "severities": ["critical", "warning"],
      "channel": "feishu_webhook",
      "reason": "scheduled regression with warning/critical severity routes to feishu oncall"
    },
    {
      "event_names": ["schedule"],
      "severities": ["info"],
      "channel": "slack_webhook",
      "reason": "scheduled regression with healthy status routes to slack digest channel"
    },
    {
      "event_names": ["workflow_dispatch"],
      "severities": ["warning", "critical"],
      "gates": ["hold", "block"],
      "failure_categories": ["permission_error", "report_parse_error"],
      "channel": "feishu_webhook",
      "reason": "manual runs with infra or report failures route to feishu for owner triage"
    },
    {
      "event_names": ["workflow_dispatch"],
      "severities": ["critical", "warning"],
      "channel": "feishu_webhook",
      "reason": "manual runs with non-green status route to feishu for fast triage"
    }
  ]
}
